{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "1. Clean",
            "type": "shell",
            "command": "make -C doomgeneric -f Makefile.mips clean",
            "group": {
                "kind": "build"
            },
            "problemMatcher": []
        },
        {
            "label": "2. Build",
            "type": "shell",
            "command": "make -C doomgeneric -f Makefile.mips all",
            "group": {
                "kind": "build"
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "3. Rebuild (Clean + Build)",
            "dependsOrder": "sequence",
            "dependsOn": [
                "1. Clean",
                "2. Build"
            ],
            "group": {
                "kind": "build"
            },
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}